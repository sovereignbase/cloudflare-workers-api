  "scripts": {
    "build": "tsup && typedoc && node in-browser-testing-build.js",
    "format": "prettier . --write"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@sovereignbase/bytecodec": "^1.7.0",
    "@sovereignbase/cryptosuite": "^2.2.0",
    "chanfana": "^2.6.3",
    "hono": "^4.12.15",
    "stripe": "^22.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/service-worker-mock": "^2.0.4",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "wrangler": "^4.86.0"
  }
}
